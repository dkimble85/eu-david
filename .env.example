# Supabase - get from https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Deployed Vercel API URL (used by the mobile app to reach /api/fatsecret)
EXPO_PUBLIC_API_URL=https://your-project.vercel.app

# FatSecret - get from https://platform.fatsecret.com/api/
# These are SERVER-SIDE ONLY - never prefix with EXPO_PUBLIC_
FATSECRET_CLIENT_ID=your-client-id
FATSECRET_CLIENT_SECRET=your-client-secret
